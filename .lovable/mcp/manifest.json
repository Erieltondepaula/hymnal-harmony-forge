{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://uocjcbahofomaczbklsl.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "mapalouvor-mcp",
      "version": "0.1.0",
      "title": "MapaLouvor"
    },
    "tools": [
      {
        "name": "list_songs",
        "title": "List songs",
        "description": "Lists the signed-in user's songs (mapas musicais) with title, artist, key, BPM, tempo and favorite flag. Optionally filter by search text.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Optional text to match against title or artist (case-insensitive)."
            },
            "favoritesOnly": {
              "type": "boolean",
              "description": "If true, only return favorites."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "description": "Max rows to return (default 50)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_song",
        "title": "Get song",
        "description": "Returns the full song map for a given song id, including all blocks (sections, chords, lyrics, repeats).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Song id (UUID)."
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_song",
        "title": "Create song",
        "description": "Creates a new song (mapa musical) for the signed-in user with title, artist, key, BPM and blocks.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "artist": {
              "type": "string"
            },
            "originalKey": {
              "type": "string",
              "description": "Original key, e.g. 'Am', 'C', 'G'."
            },
            "bpm": {
              "type": "integer",
              "minimum": 40,
              "maximum": 240
            },
            "time": {
              "type": "string",
              "description": "Time signature, e.g. '4/4'."
            },
            "rhythm": {
              "type": "string",
              "description": "Style/rhythm, e.g. 'Adoração', 'Pop Rock'."
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "blocks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Section name (e.g. INTRODUÇÃO, PARTE 1, REFRÃO)."
                  },
                  "chords": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Ordered chords for this section."
                  },
                  "repeat": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "lyric": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "note": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                },
                "required": [
                  "type",
                  "chords"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "title",
            "originalKey",
            "bpm",
            "blocks"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "delete_song",
        "title": "Delete song",
        "description": "Deletes one of the signed-in user's songs by id. This cannot be undone.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Song id (UUID) to delete."
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
